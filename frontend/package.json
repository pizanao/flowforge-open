{
  "name": "flowforge-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "check:backend": "node scripts/validate-backend-connectivity.mjs",
    "dev": "npm run check:backend && vite --host",
    "build": "vite build",
    "test:startup": "node --test tests/backend-connectivity.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:demo": "playwright test e2e/demo.spec.js --headed --project=chrome",
    "test:trace": "playwright show-trace",
    "test:codegen": "playwright codegen http://localhost:5106"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.3"
  }
}
