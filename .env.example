# FlowForge — Variáveis de Ambiente de Exemplo
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commit o arquivo .env com valores reais

# ===============================
# DJANGO (obrigatório)
# ===============================
SECRET_KEY=ALTERE_PARA_SUA_SECRET_KEY_UNICA
DEBUG=False
ALLOWED_HOSTS=localhost,flowforge.seu-dominio.com

# ===============================
# DATABASE (PostgreSQL)
# ===============================
DB_NAME=flowforge
DB_USER=flowforge
DB_PASSWORD=ALTERE_SENHA_FORTE_DO_BANCO
DB_HOST=localhost
DB_PORT=5432

# ===============================
# REDIS
# ===============================
CELERY_BROKER_URL=redis://localhost:6379/0

# ===============================
# SERVICE TOKEN (Portfolio HQ)
# ===============================
# Token compartilhado com o Auth Gateway do Portfolio HQ
PORTFOLIO_HQ_SERVICE_TOKEN=GERE_UM_TOKEN_UNICO_AQUI

# ===============================
# WEBHOOKS EXTERNOS
# ===============================
WEBHOOK_SIGNING_SECRET=GERE_UM_SEGREDO_LONGO_AQUI
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# ===============================
# OAUTH (Google + GitHub)
# ===============================
# Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-google-client-secret

# GitHub OAuth App: https://github.com/settings/developers
GITHUB_CLIENT_ID=seu-github-client-id
GITHUB_CLIENT_SECRET=seu-github-client-secret

# ===============================
# FRONTEND (Vite)
# ===============================
# Mesmos valores do OAuth acima, prefixados com VITE_
VITE_GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com
VITE_GITHUB_CLIENT_ID=seu-github-client-id

# ===============================
# URLs (ajuste para produção)
# ===============================
FRONTEND_URL=http://localhost:5106
BACKEND_URL=http://localhost:8006
BACKEND_CONNECTIVITY_PATH=/api/workflows/
BACKEND_CONNECTIVITY_RETRIES=15
BACKEND_CONNECTIVITY_TIMEOUT_MS=2000
BACKEND_CONNECTIVITY_RETRY_DELAY_MS=2000

# ===============================
# TELEGRAM (opcional)
# ===============================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===============================
# WAHA WhatsApp API (opcional)
# ===============================
WAHA_API_URL=http://localhost:3000/api
WAHA_SESSION_NAME=default
WAHA_API_KEY=
WAHA_BASE_URL=http://localhost:3000
WAHA_DEFAULT_SESSION=default
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=
WHATSAPP_HOOK_URL=http://localhost:8092/waha/webhook
WHATSAPP_HOOK_EVENTS=message,session.status
WHATSAPP_HOOK_RETRIES_ATTEMPTS=4
WHATSAPP_HOOK_RETRIES_DELAY_SECONDS=3

# ===============================
# LLM (opcional)
# ===============================
# Hugging Face Inference API
HF_TOKEN=
# Groq API (llama, mixtral, etc.)
GROQ_API_KEY=

# ===============================
# CORS (produção: defina origens explícitas)
# ===============================
CORS_ALLOWED_ORIGINS=http://localhost:5106

# ===============================
# THROTTLE
# ===============================
AUTH_THROTTLE_RATE=10/min

# ===============================
# BOOTSTRAP LOGIN (apenas dev — gere com: openssl rand -base64 24)
# ===============================
ALLOW_BOOTSTRAP_LOGIN=
